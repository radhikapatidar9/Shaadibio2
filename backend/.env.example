# Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB connection string
# For local Docker: mongodb://mongo:27017/shaadibio
# For Render: use MongoDB Atlas connection string
DATABASE_URL=mongodb://mongo:27017/shaadibio

# Port (Render injects this automatically)
PORT=5000

# Gmail SMTP credentials
# Enable 2FA on your Gmail account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=youremail@gmail.com
GMAIL_PASS=your16charapppassword

# Frontend URL (comma-separated list of allowed origins for CORS)
# For local development: http://localhost:3000
# For Render: https://your-frontend.onrender.com
# For Netlify: https://fantastic-begonia-61ea38.netlify.app
FRONTEND_URL=http://localhost:3000,https://fantastic-begonia-61ea38.netlify.app

# Cloudinary credentials (existing feature)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# JWT secret (existing feature)
JWT_SECRET=
JWT_EXPIRE=

# OTP settings (if applicable)
OTP_EXPIRE=
